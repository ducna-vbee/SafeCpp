<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Safe" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug - Static Library">
				<Option output="bin/Debug - Static Library/Safe.a" prefix_auto="0" extension_auto="0" />
				<Option working_dir="" />
				<Option object_output="obj/Debug - Static Library/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option projectIncludeDirsRelation="-1" />
				<Option projectLibDirsRelation="-1" />
				<Compiler>
					<Add option="-std=c++20" />
					<Add option="-m64" />
					<Add option="-gdwarf" />
					<Add option="-Og" />
				</Compiler>
				<Linker>
					<Add option="-static-libstdc++" />
					<Add option="-static-libgcc" />
					<Add option="-static" />
					<Add option="-m64" />
					<LinkerExe value="CppCompiler" />
				</Linker>
				<MakeCommands>
					<Build command="" />
					<CompileFile command="" />
					<Clean command="" />
					<DistClean command="" />
					<AskRebuildNeeded command="" />
					<SilentBuild command=" &gt; $(CMD_NULL)" />
				</MakeCommands>
			</Target>
			<Target title="Release - Static Library">
				<Option output="bin/Release - Static Library/Safe.a" prefix_auto="0" extension_auto="0" />
				<Option working_dir="" />
				<Option object_output="obj/Release - Static Library/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-O3" />
					<Add option="-std=c++20" />
					<Add option="-m64" />
					<Add option="-DCPP_SAFE_STATICALLY_LINKED_LIBRARY_EXPORT" />
				</Compiler>
				<Linker>
					<Add option="-O3" />
					<Add option="-static-libstdc++" />
					<Add option="-static-libgcc" />
					<Add option="-static" />
					<Add option="-m64" />
					<LinkerExe value="CppCompiler" />
				</Linker>
			</Target>
			<Target title="Debug - Dynamic Library">
				<Option output="bin/Debug - Dynamic Library/Safe.so" imp_lib="$(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).a" def_file="$(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).def" prefix_auto="0" extension_auto="0" />
				<Option working_dir="bin/Debug - Dynamic Library/" />
				<Option object_output="obj/Debug - Dynamic Library/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-std=c++20" />
					<Add option="-fPIC" />
					<Add option="-m64" />
					<Add option="-gdwarf" />
					<Add option="-Og" />
					<Add option="-DCPP_SAFE_DYNAMICALLY_LINKED_LIBRARY_EXPORT" />
				</Compiler>
				<Linker>
					<Add option="-m64" />
					<LinkerExe value="CppCompiler" />
				</Linker>
			</Target>
			<Target title="Release - Dynamic Library">
				<Option output="bin/Release - Dynamic Library/Safe.so" imp_lib="$(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).a" def_file="$(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).def" prefix_auto="0" extension_auto="0" />
				<Option working_dir="bin/Release - Dynamic Library/" />
				<Option object_output="obj/Release - Dynamic Library/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O3" />
					<Add option="-std=c++20" />
					<Add option="-fPIC" />
					<Add option="-m64" />
					<Add option="-DCPP_SAFE_DYNAMICALLY_LINKED_LIBRARY_EXPORT" />
				</Compiler>
				<Linker>
					<Add option="-O3" />
					<Add option="-m64" />
					<LinkerExe value="CppCompiler" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-std=c++20" />
			<Add option="-pg" />
			<Add option="-m64" />
			<Add option="-Og" />
			<Add option="-DCPP_SAFE_STATICALLY_LINKED_LIBRARY_EXPORT" />
		</Compiler>
		<Linker>
			<Add option="-pg" />
			<Add option="-static-libstdc++" />
			<Add option="-static-libgcc" />
			<Add option="-m64" />
		</Linker>
		<Unit filename="Safe.cpp" />
		<Unit filename="Safe.h" />
		<Unit filename="SafeContextBase.cpp" />
		<Unit filename="SafeContextBase.h" />
		<Unit filename="SafeContextException.cpp" />
		<Unit filename="SafeContextException.h" />
		<Unit filename="SafeEvent.cpp" />
		<Unit filename="SafeEvent.h" />
		<Unit filename="SafeFunction.cpp" />
		<Unit filename="SafeFunction.h" />
		<Unit filename="SafeMemoryChunk.cpp" />
